# ─────────────────────────────────────────────
#  VOID Esport — Variables d'environnement
#  Copie ce fichier en .env et remplis les valeurs
# ─────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────
# Mot de passe pour l'utilisateur "void" dans le container DB
POSTGRES_PASSWORD=changeme

# URL de connexion (construite automatiquement par docker-compose)
# Ne change que si tu utilises une DB externe
DATABASE_URL=postgresql://void:changeme@db:5432/void_esport

# ── Discord OAuth2 ────────────────────────────
# https://discord.com/developers/applications → ton app → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Ajoute dans Discord → Redirects : http://TON_IP_RPI/players-login

# ── JWT ───────────────────────────────────────
# Génère un secret avec :
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# ── PayPal API officielle (Transactions Reporting) ────
# Crée une app sur https://developer.paypal.com/dashboard/applications
# Permissions requises : "Transaction Search" (compte Business obligatoire)
# L'environnement (live/sandbox) est contrôlable depuis /meonix/tips
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Optionnel : environnement par défaut si jamais réglé depuis l'admin (live | sandbox)
# PAYPAL_ENV=live

# ── PayPal API perso (legacy, optionnel) ──────
# Token Bearer pour l'ancienne API paypal.meonix.me (lib `paypalMeonix.ts`)
# Plus utilisé par défaut depuis le retour à l'API PayPal officielle.
# PAYPAL_MEONIX_TOKEN=
# PAYPAL_MEONIX_URL=https://paypal.meonix.me

# ── Ports ─────────────────────────────────────
# Port interne de l'API server (défaut: 8080)
# Utilisé par Node.js ET transmis à nginx pour le proxy_pass
PORT=8080

# Port HTTP exposé par nginx sur le Raspberry Pi (défaut: 80)
WEB_PORT=80
