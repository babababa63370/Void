# ─────────────────────────────────────────────
#  VOID Esport — Variables d'environnement
#  Copie ce fichier en .env et remplis les valeurs
# ─────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────
# Mot de passe pour l'utilisateur "void" dans le container DB
POSTGRES_PASSWORD=changeme

# URL de connexion (construite automatiquement par docker-compose)
# Ne change que si tu utilises une DB externe
DATABASE_URL=postgresql://void:changeme@db:5432/void_esport

# ── Discord OAuth2 ────────────────────────────
# https://discord.com/developers/applications → ton app → OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Ajoute dans Discord → Redirects : http://TON_IP_RPI/players-login

# ── JWT ───────────────────────────────────────
# Génère un secret avec :
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# ── PayPal / API Dons (paypal.meonix.me) ─────
# Token Bearer pour l'API personnelle de gestion des dons.
# Doit correspondre à la valeur de `MDP` dans l'app Flask paypal.meonix.me.
PAYPAL_MEONIX_TOKEN=

# Optionnel : URL de base de l'API dons (défaut: https://paypal.meonix.me)
# PAYPAL_MEONIX_URL=https://paypal.meonix.me

# ── PayPal officiel (legacy, plus utilisé par défaut) ─
# Conservés pour compatibilité avec l'ancien lib `src/lib/paypal.ts`.
# Laisser vides si la sync passe par paypal.meonix.me.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── Ports ─────────────────────────────────────
# Port interne de l'API server (défaut: 8080)
# Utilisé par Node.js ET transmis à nginx pour le proxy_pass
PORT=8080

# Port HTTP exposé par nginx sur le Raspberry Pi (défaut: 80)
WEB_PORT=80
