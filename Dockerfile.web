# ─── Build stage ──────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

RUN npm install -g pnpm@10

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY . .

# Retire toutes les exclusions de binaires natifs générées sous x86_64 par Replit
# (esbuild, rollup, lightningcss, tailwindcss/oxide…)
# afin que pnpm installe automatiquement les bons binaires pour la plateforme cible
RUN sed -i "/: '-'$/d" pnpm-lock.yaml

RUN pnpm install --no-frozen-lockfile --force

ENV BASE_PATH=/ NODE_ENV=production PORT=80
RUN pnpm --filter @workspace/void-esport run build

# ─── Runner stage (nginx) ─────────────────────────────────────────────────────
FROM nginx:alpine AS runner

COPY --from=builder /app/artifacts/void-esport/dist/public /usr/share/nginx/html
COPY nginx.conf /etc/nginx/templates/default.conf.template

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
