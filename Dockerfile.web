# ─── Build stage ──────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

RUN npm install -g pnpm@10

WORKDIR /app

COPY package.json pnpm-workspace.yaml ./
COPY . .

# Supprime le lockfile généré sous x86_64 : les binaires natifs optionnels
# (rollup, esbuild, lightningcss…) n'y sont pas résolus pour arm64.
# pnpm résout tout depuis zéro et installe les bons binaires pour la plateforme cible.
RUN rm pnpm-lock.yaml && pnpm install

ENV BASE_PATH=/ NODE_ENV=production PORT=80
RUN pnpm --filter @workspace/void-esport run build

# ─── Runner stage (nginx) ─────────────────────────────────────────────────────
FROM nginx:alpine AS runner

COPY --from=builder /app/artifacts/void-esport/dist/public /usr/share/nginx/html
COPY nginx.conf /etc/nginx/templates/default.conf.template

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
