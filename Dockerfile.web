# ─── Build stage ──────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

RUN npm install -g pnpm@10

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY . .

# Retire toutes les exclusions ARM64 (gnu + musl) générées sous x86_64 par Replit
# afin que pnpm installe les bons binaires natifs sur arm64 (musl/Alpine ou gnu/Debian)
RUN sed -i "/-linux-arm64-musl: '-'/d" pnpm-lock.yaml && \
    sed -i "/-linux-arm64-gnu: '-'/d" pnpm-lock.yaml

RUN pnpm install --no-frozen-lockfile --force

ENV BASE_PATH=/ NODE_ENV=production PORT=80
RUN pnpm --filter @workspace/void-esport run build

# ─── Runner stage (nginx) ─────────────────────────────────────────────────────
FROM nginx:alpine AS runner

COPY --from=builder /app/artifacts/void-esport/dist/public /usr/share/nginx/html
COPY nginx.conf /etc/nginx/templates/default.conf.template

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
