# ─── Build stage ──────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

RUN npm install -g pnpm@10

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY . .

# Retire les exclusions ARM64 musl ajoutées par Replit (x86_64) pour que
# pnpm installe automatiquement les bons binaires natifs sur Raspberry Pi
RUN sed -i "/lightningcss>lightningcss-linux-arm64-musl: '-'/d" pnpm-lock.yaml && \
    sed -i "/'@tailwindcss\/oxide>@tailwindcss\/oxide-linux-arm64-musl': '-'/d" pnpm-lock.yaml && \
    sed -i "/rollup>@rollup\/rollup-linux-arm64-musl: '-'/d" pnpm-lock.yaml

RUN pnpm install --no-frozen-lockfile

ENV BASE_PATH=/ NODE_ENV=production
RUN pnpm --filter @workspace/void-esport run build

# ─── Runner stage (nginx) ─────────────────────────────────────────────────────
FROM nginx:alpine AS runner

COPY --from=builder /app/artifacts/void-esport/dist/public /usr/share/nginx/html
COPY nginx.conf /etc/nginx/templates/default.conf.template

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
