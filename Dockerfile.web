# ─── Build stage ──────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

RUN npm install -g pnpm@10

WORKDIR /app

# Fichiers de config workspace (cache Docker optimisé)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./

# package.json de chaque workspace utilisé par void-esport
COPY lib/api-client-react/package.json    ./lib/api-client-react/
COPY lib/object-storage-web/package.json  ./lib/object-storage-web/
COPY artifacts/void-esport/package.json   ./artifacts/void-esport/

RUN pnpm install --no-frozen-lockfile

# Sources
COPY lib/api-client-react/                ./lib/api-client-react/
COPY lib/object-storage-web/              ./lib/object-storage-web/
COPY artifacts/void-esport/               ./artifacts/void-esport/

# Build Vite (sortie → artifacts/void-esport/dist/public/)
ENV BASE_PATH=/ NODE_ENV=production
RUN pnpm --filter @workspace/void-esport run build

# ─── Runner stage (nginx) ─────────────────────────────────────────────────────
FROM nginx:alpine AS runner

COPY --from=builder /app/artifacts/void-esport/dist/public /usr/share/nginx/html

# Template nginx — envsubst remplace ${API_PORT} au démarrage du container
COPY nginx.conf /etc/nginx/templates/default.conf.template

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
