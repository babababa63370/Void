# ─── Build stage ──────────────────────────────────────────────────────────────
FROM node:24-alpine AS builder

RUN npm install -g pnpm@10

WORKDIR /app

# Copie les fichiers de config workspace en premier (cache Docker)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY patches/ ./patches/ 2>/dev/null || true

# Copie les package.json de chaque workspace
COPY lib/db/package.json ./lib/db/
COPY lib/api-zod/package.json ./lib/api-zod/ 2>/dev/null || true
COPY artifacts/void-esport/package.json ./artifacts/void-esport/

# Install des dépendances
RUN pnpm install --frozen-lockfile

# Copie les sources
COPY lib/ ./lib/
COPY artifacts/void-esport/ ./artifacts/void-esport/

# Build Vite (sortie → artifacts/void-esport/dist/public/)
ENV BASE_PATH=/ NODE_ENV=production
RUN pnpm --filter @workspace/void-esport run build

# ─── Runner stage (nginx) ─────────────────────────────────────────────────────
FROM nginx:alpine AS runner

# Copie les fichiers statiques buildés
COPY --from=builder /app/artifacts/void-esport/dist/public /usr/share/nginx/html

# Copie la config nginx
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
